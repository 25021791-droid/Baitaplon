<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="600.0" prefWidth="800.0" spacing="15.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.SellerController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label text="Khu vực Người Bán (Seller Dashboard)">
        <font>
            <Font name="System Bold" size="24.0" />
        </font>
    </Label>

    <VBox spacing="10.0" style="-fx-border-color: #cccccc; -fx-border-radius: 5; -fx-padding: 15;">
        <Label text="Tạo phiên đấu giá mới" textFill="#333333">
            <font>
                <Font name="System Bold" size="16.0" />
            </font>
        </Label>

        <HBox spacing="15.0" alignment="CENTER_LEFT">
            <VBox spacing="5.0">
                <Label text="Tên sản phẩm:" />
                <TextField fx:id="txtItemName" prefWidth="250.0" promptText="Nhập tên sản phẩm..." />
            </VBox>
            <VBox spacing="5.0">
                <Label text="Giá khởi điểm ($):" />
                <TextField fx:id="txtStartPrice" prefWidth="150.0" promptText="VD: 100.0" />
            </VBox>
            <VBox alignment="BOTTOM_LEFT" spacing="5.0">
                <Button fx:id="btnCreateAuction" mnemonicParsing="false" prefHeight="25.0" style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-weight: bold;" text="Tạo Phiên" />
            </VBox>
        </HBox>
    </VBox>

    <Label text="Danh sách các phiên đấu giá của tôi:">
        <font>
            <Font name="System Bold" size="16.0" />
        </font>
        <VBox.margin>
            <Insets top="10.0" />
        </VBox.margin>
    </Label>

    <TableView fx:id="tableMyAuctions" prefHeight="350.0" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn prefWidth="75.0" text="ID" />
            <TableColumn prefWidth="250.0" text="Tên Sản Phẩm" />
            <TableColumn prefWidth="150.0" text="Giá Hiện Tại" />
            <TableColumn prefWidth="150.0" text="Trạng Thái" />
        </columns>
    </TableView>
</VBox>