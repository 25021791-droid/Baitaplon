<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<VBox prefWidth="180.0" prefHeight="260.0" style="-fx-background-color: white; -fx-background-radius: 5; -fx-border-color: #e0e0e0; -fx-border-radius: 5; -fx-padding: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 2);" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.BidderCardController">
    <children>
        <ImageView fx:id="imgItem" fitHeight="120.0" fitWidth="160.0" pickOnBounds="true" preserveRatio="true" />

        <!-- SỬA: Spacer → Region -->
        <Region prefHeight="10.0" />

        <Label fx:id="lblCategory" text="VEHICLE" style="-fx-text-fill: #1d72b8; -fx-font-size: 10px; -fx-font-weight: bold;" />

        <Label fx:id="lblTitle" text="Tên sản phẩm đấu giá" style="-fx-font-size: 14px; -fx-font-weight: bold;" wrapText="true" prefHeight="40.0"/>

        <!-- SỬA: Spacer → Region -->
        <Region prefHeight="15.0" />

        <HBox alignment="BOTTOM_LEFT">
            <children>
                <VBox HBox.hgrow="ALWAYS">
                    <children>
                        <Label text="Giá hiện tại" style="-fx-font-size: 10px; -fx-text-fill: gray;" />
                        <Label fx:id="lblPrice" text="đ 1,100" style="-fx-font-size: 13px; -fx-font-weight: bold;" />
                    </children>
                </VBox>
                <VBox alignment="BOTTOM_RIGHT">
                    <children>
                        <Label text="Còn lại" style="-fx-font-size: 10px; -fx-text-fill: gray;" />
                        <Label fx:id="lblTime" text="41d 4h" style="-fx-font-size: 11px; -fx-font-weight: bold;" />
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</VBox>