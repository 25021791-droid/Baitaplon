<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="700.0" prefWidth="900.0" spacing="15.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.SellerController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <BorderPane prefHeight="65.0" style="-fx-background-color: #2c3e50; -fx-padding: 10 20 10 20; -fx-background-radius: 5;">
        <left>
            <HBox alignment="CENTER_LEFT" spacing="15.0" BorderPane.alignment="CENTER">
                <children>
                    <StackPane onMouseClicked="#handleProfile" style="-fx-background-color: #3498db; -fx-background-radius: 50; -fx-cursor: hand;" prefWidth="40.0" prefHeight="40.0" minWidth="40.0" minHeight="40.0">
                        <children>
                            <Label fx:id="lblAvatarLetter" text="S" textFill="WHITE" style="-fx-font-weight: bold; -fx-font-size: 16.0;" />
                        </children>
                    </StackPane>
                    <VBox alignment="CENTER_LEFT" spacing="3.0">
                        <children>
                            <Label fx:id="lblUsername" text="Seller: Chưa đăng nhập" textFill="WHITE">
                                <font>
                                    <Font name="System Bold" size="14.0" />
                                </font>
                            </Label>
                        </children>
                    </VBox>
                </children>
            </HBox>
        </left>
        <center>
            <Label text="KHU VỰC NGƯỜI BÁN" textFill="WHITE" BorderPane.alignment="CENTER">
                <font>
                    <Font name="System Bold" size="20.0" />
                </font>
            </Label>
        </center>
        <right>
            <HBox alignment="CENTER_RIGHT" spacing="10.0" BorderPane.alignment="CENTER">
                <children>
                    <Button mnemonicParsing="false" onAction="#handleLogout" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold;" text="Đăng Xuất" />
                </children>
            </HBox>
        </right>
    </BorderPane>

    <VBox spacing="10.0" style="-fx-border-color: #cccccc; -fx-border-radius: 5; -fx-padding: 15;">
        <Label text="Tạo phiên đấu giá mới" textFill="#333333">
            <font>
                <Font name="System Bold" size="16.0" />
            </font>
        </Label>

        <HBox alignment="CENTER_LEFT" spacing="15.0">
            <VBox spacing="5.0">
                <Label text="Tên sản phẩm:" />
                <TextField fx:id="txtItemName" prefWidth="200.0" promptText="Nhập tên sản phẩm..." />
            </VBox>
            <VBox spacing="5.0">
                <Label text="Giá khởi điểm (VNĐ):" />
                <TextField fx:id="txtStartPrice" prefWidth="120.0" promptText="VD: 100000" />
            </VBox>
            <VBox spacing="5.0">
                <Label text="Thời gian đấu giá (phút):" />
                <TextField fx:id="txtDuration" prefWidth="120.0" promptText="VD: 1440" />
            </VBox>
            <VBox spacing="5.0">
                <Label text="Hình ảnh:" />
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <Button fx:id="btnChooseImage" mnemonicParsing="false" style="-fx-background-color: #3498db; -fx-text-fill: white;" text="Chọn Ảnh" />
                    <Label fx:id="lblImageName" text="Chưa chọn ảnh" textFill="#999999" />
                </HBox>
            </VBox>
        </HBox>

        <HBox alignment="CENTER_LEFT" spacing="15.0">
            <ImageView fx:id="imgPreview" fitHeight="120.0" fitWidth="160.0" preserveRatio="true" visible="false" />
        </HBox>

        <HBox>
            <Button fx:id="btnCreateAuction" mnemonicParsing="false" prefHeight="30.0" style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-weight: bold;" text="Tạo Phiên" />
        </HBox>
    </VBox>

    <Label text="Danh sách các phiên đấu giá của tôi:">
        <font>
            <Font name="System Bold" size="16.0" />
        </font>
        <VBox.margin>
            <Insets top="10.0" />
        </VBox.margin>
    </Label>

    <TableView fx:id="tableMyAuctions" prefHeight="350.0" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn prefWidth="75.0" text="ID" />
            <TableColumn prefWidth="250.0" text="Tên Sản Phẩm" />
            <TableColumn prefWidth="150.0" text="Giá Hiện Tại" />
            <TableColumn prefWidth="150.0" text="Trạng Thái" />
        </columns>
    </TableView>
</VBox>