<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.AuctionController">

    <top>
        <GridPane style="-fx-background-color: #2c3e50; -fx-padding: 10;">
            <columnConstraints>
                <ColumnConstraints percentWidth="33.3" halignment="LEFT" />
                <ColumnConstraints percentWidth="33.4" halignment="CENTER" />
                <ColumnConstraints percentWidth="33.3" halignment="RIGHT" />
            </columnConstraints>
            <children>
                <Label fx:id="lblUsername" text="User: ..." textFill="WHITE" style="-fx-font-weight: bold;" GridPane.columnIndex="0" />

                <Button text="Logout" onAction="#handleBackToLogin" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" GridPane.columnIndex="2" />
            </children>
        </GridPane>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="20.0" BorderPane.alignment="CENTER">
            <children>
                <Label text="AUCTION SCREEN" style="-fx-font-size: 20px; -fx-font-weight: bold;" />

                <HBox alignment="CENTER" spacing="10">
                    <TextField fx:id="bidField" promptText="Nhập giá tiền..." />
                    <Button onAction="#handleBid" text="Place Bid" style="-fx-background-color: #3498db; -fx-text-fill: white;" />
                </HBox>

                <Label fx:id="resultLabel" text="..." />
            </children>
        </VBox>
    </center>

</BorderPane>