<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<VBox alignment="CENTER" prefHeight="650.0" prefWidth="500.0" spacing="0"
      style="-fx-background-color: #99cde6;"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.client.controller.LoginController"
      stylesheets="@style.css">

   <children>
      <VBox alignment="TOP_LEFT" maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="580.0" prefWidth="440.0" spacing="20.0" style="-fx-background-color: #ffffff; -fx-background-radius: 10px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
         <children>
            <VBox alignment="TOP_CENTER" spacing="10.0">
               <children>
                  <Label text="ĐĂNG NHẬP" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #000000;" />
               </children>
            </VBox>

            <VBox spacing="8.0">
               <children>
                  <Label text="Tên đăng nhập" style="-fx-font-size: 14px; -fx-text-fill: #000000;" />
                  <TextField fx:id="usernameField" promptText="tên" styleClass="input-field" />
               </children>
            </VBox>

            <VBox spacing="8.0">
               <children>
                  <Label text="Mật khẩu" style="-fx-font-size: 14px; -fx-text-fill: #000000;" />
                  <PasswordField fx:id="passwordField" promptText="mật khẩu" styleClass="input-field" />
               </children>
            </VBox>

            <Button fx:id="loginButton" onAction="#handleLogin" text="ĐĂNG NHẬP" maxWidth="1.7976931348623157E308" styleClass="login-button" style="-fx-text-fill: #ffffff; -fx-font-weight: bold; -fx-font-size: 14px; -fx-border-color: #3b82f6; -fx-background-color: #3b82f6" />

            <Label fx:id="messageLabel" text="" textFill="red" visible="false" />

            <HBox alignment="CENTER" spacing="5.0">
               <children>
                  <Label text="Bạn chưa có tài khoản?" style="-fx-font-size: 14px; -fx-text-fill: #6b7280;" />
                  <Button onAction="#handleBackToRegister" text="Đăng kí" style="-fx-background-color: transparent; -fx-padding: 0; -fx-text-fill: #3b82f6; -fx-font-weight: bold; -fx-font-size: 14px; -fx-cursor: hand;" />
               </children>
               <padding>
                  <Insets top="10.0" />
               </padding>
            </HBox>
         </children>
         <padding>
            <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
         </padding>
      </VBox>
   </children>
</VBox>