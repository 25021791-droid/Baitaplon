<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="TOP_CENTER" prefHeight="600.0" prefWidth="800.0" spacing="15.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.BiddingRoomController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label fx:id="productNameLabel" text="Tên sản phẩm: Điện thoại iPhone 15 Pro Max">
        <font>
            <Font name="System Bold" size="24.0" />
        </font>
    </Label>

    <HBox alignment="CENTER" spacing="20.0">
        <Label text="Giá hiện tại cao nhất:" />
        <Label fx:id="currentPriceLabel" text="25,000,000 VNĐ" textFill="RED">
            <font>
                <Font name="System Bold" size="18.0" />
            </font>
        </Label>
    </HBox>

    <HBox alignment="CENTER" spacing="20.0">
        <Label text="Thời gian còn lại:" />
        <Label fx:id="timeRemainingLabel" text="00:05:30" textFill="BLUE">
            <font>
                <Font name="System Bold" size="14.0" />
            </font>
        </Label>
    </HBox>

    <HBox alignment="CENTER" spacing="10.0">
        <TextField fx:id="bidAmountInput" prefWidth="250.0" promptText="23800" />
        <Button fx:id="placeBidButton" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="Đặt Giá Ngay" />
    </HBox>

    <VBox fx:id="chartContainer" minHeight="350.0" style="-fx-border-color: lightgray; -fx-border-width: 1; -fx-background-color: white;" VBox.vgrow="ALWAYS">
        <VBox.margin>
            <Insets top="10.0" />
        </VBox.margin>
    </VBox>
</VBox>
